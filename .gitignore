# ============================================
# WordPress Safe .gitignore (Final Stable)
# ============================================

# ---------------------------
# WordPress Sensitive
# ---------------------------
wp-config.php
.env
.env.*
*.env

# ---------------------------
# Uploads & Runtime
# ---------------------------
wp-content/uploads/
wp-content/upgrade/
wp-content/cache/

# ---------------------------
# Logs
# ---------------------------
*.log
*.logs
debug.log
wp-content/debug.log
error_log

# ---------------------------
# Security Files
# ---------------------------
*.pem
*.key
*.cert
*.p12
auth.json
secrets.json

# ---------------------------
# OS Files
# ---------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------
# IDE
# ---------------------------
.vscode/
.idea/

# ---------------------------
# Node / Build
# ---------------------------
node_modules/
dist/
build/
.cache/
.sass-cache/

# ---------------------------
# PHP / Composer
# ---------------------------
# vendor/   ← only ignore if NOT using composer

# ---------------------------
# Temp
# ---------------------------
*.bak
*.tmp
*.temp
*.swp
*.swo
*~

# ---------------------------
# WP Plugin Junk
# ---------------------------
wp-content/backups/
wp-content/et-cache/
wp-content/w3tc-config/
wp-content/wp-cache-config.php
wflogs/

# ---------------------------
# AI SYSTEM (IMPORTANT)
# ---------------------------
/wp-content/ai/

# ---------------------------
# Deploy
# ---------------------------
deploy.php
deployer.phar
Capfile

# ============================================
# DO NOT IGNORE (IMPORTANT)
# ============================================
# .git/
# wp-content/plugins/
# wp-content/themes/
# README.md